---
import "../styles/global.css";
// Component Imports
import Hero from "../components/Hero.astro";
import InvitationGate from "../components/InvitationGate.astro";
import Quote from "../components/Quote.astro";
import Couple from "../components/Couple.astro";
import Story from "../components/Story.astro";
import Gallery from "../components/Gallery.astro";
import Event from "../components/Event.astro";
import Countdown from "../components/Countdown.astro";
import RSVP from "../components/RSVP.astro";
import Wish from "../components/Wish.astro";
import WeddingGift from "../components/WeddingGift.astro";
import Closing from "../components/Closing.astro";
import FloatingNav from "../components/FloatingNav.astro"; // Navigasi melayang (Musik & Tombol Atas)

// --- KONFIGURASI VISIBILITAS SECTION ---
// Ubah ke 'false' jika ingin menyembunyikan section tertentu tanpa menghapus kode.
const SECTION_VISIBILITY = {
	quote: true,
	couple: true,
	story: true,
	gallery: true,
	event: true,
	countdown: false,
	rsvp: true,
	wish: true,
	gift: true,
	closing: true,
};

// --- KONFIGURASI GLOBAL DATA PERNIKAHAN ---
// Cukup ganti di sini untuk merubah nama di seluruh website
const WEDDING_CONFIG = {
	groom: {
		name: "Umay",
		parentFather: "Bapak Lord Bandung",
		parentMother: "Ibu Lady Bandung",
		image: "/assets/umar-1.png",
	},
	bride: {
		name: "Amelia",
		parentFather: "Bapak Amelia",
		parentMother: "Ibu Amelia",
		image: "/assets/leay-1.png",
	},
	// // indonesia: Ganti foto background hero di sini
	heroBackground: "/assets/bghero.jpg",
	// // indonesia: Foto-foto khusus untuk layout Grid (kotak-kotak)
	galleryGridImages: [
		"/assets/slide1.jpg",
		"/assets/slide2.jpg",
		"/assets/slide3.jpg",
		"/assets/slide4.jpg",
		"/assets/slide5.jpg",
		"/assets/slide6.jpg",
	],
	// // indonesia: Foto-foto khusus untuk layout Slider (geser)
	gallerySliderImages: [
		"/assets/slide1.jpg",
		"/assets/slide2.jpg",
		"/assets/slide3.jpg",
		"/assets/slide4.jpg",
		"/assets/slide5.jpg",
		"/assets/slide6.jpg",
	],
	// // indonesia: Aktifkan (true) atau Nonaktifkan (false) layout Gallery
	showGalleryGrid: true,
	showGallerySlider: true,
};
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body class="overflow-x-hidden">
		<InvitationGate {...WEDDING_CONFIG} />
		<Hero {...WEDDING_CONFIG} />
		{SECTION_VISIBILITY.quote && <Quote />}
		{SECTION_VISIBILITY.couple && <Couple {...WEDDING_CONFIG} />}
		{SECTION_VISIBILITY.story && <Story />}
		{SECTION_VISIBILITY.gallery && <Gallery {...(WEDDING_CONFIG as any)} />}
		{SECTION_VISIBILITY.event && <Event {...WEDDING_CONFIG} />}
		{SECTION_VISIBILITY.countdown && <Countdown />}
		{SECTION_VISIBILITY.rsvp && <RSVP />}
		{SECTION_VISIBILITY.wish && <Wish />}
		{SECTION_VISIBILITY.gift && <WeddingGift {...WEDDING_CONFIG} />}
		{SECTION_VISIBILITY.closing && <Closing {...WEDDING_CONFIG} />}
		<FloatingNav />
	</body>
</html>
