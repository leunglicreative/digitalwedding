---
import "../styles/global.css";
// Component Imports
import Hero from "../components/Hero.astro";
import Quote from "../components/Quote.astro";
import Couple from "../components/Couple.astro";
import Story from "../components/Story.astro";
import Gallery from "../components/Gallery.astro";
import Event from "../components/Event.astro";
import Countdown from "../components/Countdown.astro";
import RSVP from "../components/RSVP.astro";
import Wish from "../components/Wish.astro";
import WeddingGift from "../components/WeddingGift.astro";
import Closing from "../components/Closing.astro";
import FloatingNav from "../components/FloatingNav.astro"; // Navigasi melayang (Musik & Tombol Atas)

// --- KONFIGURASI ANIMASI PER SECTION ---
// ENABLE_ANIMATION_GLOBAL: Tombol utama untuk mengaktifkan/menonaktifkan semua efek animasi muncul (scroll reveal).
const ENABLE_ANIMATION_GLOBAL = true; // true = Aktif, false = Nonaktif

/**
 * SECTION_ANIMATIONS: Tentukan jenis animasi untuk setiap bagian secara spesifik.
 * Pilihan Efek:
 * - 'fade-up'    : Muncul dari bawah
 * - 'fade-down'  : Muncul dari atas
 * - 'fade-left'  : Muncul dari kiri
 * - 'fade-right' : Muncul dari kanan
 * - 'zoom-in'    : Membesar dari tengah
 * - 'zoom-out'   : Mengecil dari luar
 * - 'flip-up'    : Terbalik dari bawah
 */
const SECTION_ANIMATIONS = {
	quote: "fade-up",
	couple: "zoom-in",
	story: "fade-right",
	gallery: "fade-left",
	event: "fade-up",
	rsvp: "zoom-in",
	wish: "fade-right",
	gift: "fade-left",
	closing: "fade-up",
};

// --- KONFIGURASI VISIBILITAS SECTION ---
// Ubah ke 'false' jika ingin menyembunyikan section tertentu tanpa menghapus kode.
const SECTION_VISIBILITY = {
	quote: true,
	couple: true,
	story: true,
	gallery: true,
	event: true,
	countdown: false,
	rsvp: true,
	wish: true,
	gift: true,
	closing: true,
};
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{
			/* CARA MENGGANTI JUDUL BROWSER: Ganti teks di dalam tag <title> di bawah ini */
		}
		<title>The Wedding of Umar & Eliza</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body class="overflow-x-hidden">
		{
			/* Hero section tidak menggunakan efek reveal scroll (sudah ada animasi pembuka) */
		}
		<Hero />

		{
			/* Bungkus setiap section dengan class 'reveal' dan tipe animasi yang dipilih jika fitur diaktifkan */
			/* Gunakan SECTION_VISIBILITY untuk menentukan apakah section harus muncul atau tidak */
		}

		{
			SECTION_VISIBILITY.quote && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.quote}`
							: ""
					}
				>
					<Quote />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.couple && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.couple}`
							: ""
					}
				>
					<Couple />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.story && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.story}`
							: ""
					}
				>
					<Story />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.gallery && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.gallery}`
							: ""
					}
				>
					<Gallery />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.event && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.event}`
							: ""
					}
				>
					<Event />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.countdown && (
				/* REVEAL sekarang ditangani langsung di dalam component Countdown untuk transisi background yang lebih mulus */
				<Countdown />
			)
		}

		{
			SECTION_VISIBILITY.rsvp && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.rsvp}`
							: ""
					}
				>
					<RSVP />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.wish && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.wish}`
							: ""
					}
				>
					<Wish />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.gift && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.gift}`
							: ""
					}
				>
					<WeddingGift />
				</div>
			)
		}

		{
			SECTION_VISIBILITY.closing && (
				<div
					class={
						ENABLE_ANIMATION_GLOBAL
							? `reveal ${SECTION_ANIMATIONS.closing}`
							: ""
					}
				>
					<Closing />
				</div>
			)
		}

		{/* Navigasi Melayang (Tombol Musik & Back to Top) */}
		<FloatingNav />

		<script is:inline define:vars={{ ENABLE_ANIMATION_GLOBAL }}>
			// --- LOGIKA PENGUNCIAN SCROLL (HARD LOCK) ---
			function lockScroll() {
				document.documentElement.style.overflow = "hidden";
				document.body.style.overflow = "hidden";
				document.body.style.height = "100%";
			}

			function unlockScroll() {
				document.documentElement.style.overflow = "";
				document.body.style.overflow = "";
				document.body.style.height = "";
			}

			// Kunci saat pertama kali load
			lockScroll();

			// Dengarkan event dari Hero.astro saat undangan dibuka
			document.addEventListener("open-invitation", () => {
				unlockScroll();
			});

			// --- LOGIKA MUNCUL SAAT SCROLL (SCROLL REVEAL OPTIMIZED) ---
			if (ENABLE_ANIMATION_GLOBAL) {
				const observerOptions = {
					threshold: 0.15, // Section akan muncul jika 15% areanya terlihat di layar
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("active");
							// OPTIMASI: Berhenti mengamati setelah elemen muncul agar tidak membebani performa mobile
							observer.unobserve(entry.target);
						}
					});
				}, observerOptions);

				// Cari semua elemen dengan class .reveal dan mulai mengamati
				document.querySelectorAll(".reveal").forEach((el) => {
					observer.observe(el);
				});
			}
		</script>
	</body>
</html>

<style is:global>
	/* --- SISTEM ANIMASI KOMPLEKS (SCROLL REVEAL) --- */

	/* Keadaan awal (Hidden) */
	.reveal {
		opacity: 0;
		transition: all 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		will-change: transform, opacity;
	}

	/* 1. Fade Up */
	.reveal.fade-up {
		transform: translateY(50px);
	}

	/* 2. Fade Down */
	.reveal.fade-down {
		transform: translateY(-50px);
	}

	/* 3. Fade Left */
	.reveal.fade-left {
		transform: translateX(50px);
	}

	/* 4. Fade Right */
	.reveal.fade-right {
		transform: translateX(-50px);
	}

	/* 5. Zoom In */
	.reveal.zoom-in {
		transform: scale(0.8);
	}

	/* 6. Zoom Out */
	.reveal.zoom-out {
		transform: scale(1.2);
	}

	/* 7. Flip Up */
	.reveal.flip-up {
		transform: perspective(1000px) rotateX(-30deg);
	}

	/* Keadaan Akhir (Show/Active) ketika terpapar Intersection Observer */
	.reveal.active {
		opacity: 1;
		transform: translate(0, 0) scale(1) rotateX(0) rotateY(0) !important;
	}
</style>
