---
import "../styles/global.css";
// Component Imports
import Hero from "../components/Hero.astro";
import Quote from "../components/Quote.astro";
import Couple from "../components/Couple.astro";
import Story from "../components/Story.astro";
import Gallery from "../components/Gallery.astro";
import Event from "../components/Event.astro";
import Countdown from "../components/Countdown.astro";
import RSVP from "../components/RSVP.astro";
import Wish from "../components/Wish.astro";
import WeddingGift from "../components/WeddingGift.astro";
import Closing from "../components/Closing.astro";
import FloatingNav from "../components/FloatingNav.astro"; // Navigasi melayang (Musik & Tombol Atas)

// --- KONFIGURASI HALAMAN UTAMA ---
// Tentukan apakah ingin menggunakan efek muncul (fade) saat scroll.
const ENABLE_FADE_SCROLL = true; // true = Aktif, false = Nonaktif
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{
			/* CARA MENGGANTI JUDUL BROWSER: Ganti teks di dalam tag <title> di bawah ini */
		}
		<title>The Wedding of Umar & Eliza</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body>
		{
			/* Hero section tidak menggunakan efek reveal scroll (sudah ada animasi pembuka) */
		}
		<Hero />

		{/* Bungkus section lain dengan class .reveal jika fitur diaktifkan */}
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><Quote /></div>
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><Couple /></div>
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><Story /></div>
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><Gallery /></div>
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><Event /></div>
		{
			/* REVEAL sekarang ditangani langsung di dalam component Countdown untuk transisi background yang lebih mulus */
		}
		<Countdown />
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><RSVP /></div>
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><Wish /></div>
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><WeddingGift /></div>
		<div class={ENABLE_FADE_SCROLL ? "reveal" : ""}><Closing /></div>

		{/* Navigasi Melayang (Tombol Musik & Back to Top) */}
		<FloatingNav />

		<script is:inline define:vars={{ ENABLE_FADE_SCROLL }}>
			// --- LOGIKA MUNCUL SAAT SCROLL (SCROLL REVEAL) ---
			if (ENABLE_FADE_SCROLL) {
				const observerOptions = {
					threshold: 0.15, // Section akan muncul jika 15% areanya terlihat di layar
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("active");
							// Berhenti mengamati setelah elemen muncul agar animasi cuma sekali saja (opsional)
							// observer.unobserve(entry.target);
						}
					});
				}, observerOptions);

				// Cari semua elemen dengan class .reveal dan mulai mengamati
				document.querySelectorAll(".reveal").forEach((el) => {
					observer.observe(el);
				});
			}
		</script>
	</body>
</html>
