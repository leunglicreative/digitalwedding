---
/* 
   MODIFIKASI EVENT DETAIL:
   - Ganti link Google Maps dengan link lokasi acara asli.
   - Edit tanggal, waktu, dan lokasi resepsi/akad.
   - Menggunakan data dari props index.astro.
*/
interface Props {
    groom: { name: string };
    bride: { name: string };
}

const { groom, bride } = Astro.props;
---

<section id="event" class="py-20 bg-soft-white px-4 text-center">
    <div class="max-w-4xl mx-auto">
        <h2 class="font-serif text-4xl md:text-5xl text-gold mb-16 italic">
            Event Details
        </h2>

        <div class="grid md:grid-cols-2 gap-12">
            <!-- Akad Nikah -->
            <div
                class="p-8 bg-white shadow-xl rounded-lg border border-gold/20"
            >
                <h3 class="font-serif text-3xl text-gold mb-4 italic">
                    Akad Nikah
                </h3>
                <p class="text-gray-600 mb-2">Minggu, 12 Desember 2026</p>
                <p
                    class="text-gray-600 mb-4 font-semibold uppercase tracking-widest"
                >
                    08:00 - 10:00 WIB
                </p>
                <p class="text-gray-800 font-serif italic mb-8">
                    Masjid Raya Al-Muhajirin <br /> Jakarta Selatan
                </p>

                <div class="flex flex-col gap-4">
                    <a
                        href={`https://calendar.google.com/calendar/render?action=TEMPLATE&text=Akad+Nikah+${groom.name}+%26+${bride.name}&dates=20261212T010000Z/20261212T030000Z&details=Akad+Nikah+${groom.name}+and+${bride.name}&location=Masjid+Raya+Al-Muhajirin`}
                        target="_blank"
                        class="bg-gold text-white px-6 py-2 rounded-full text-sm font-semibold hover:bg-[#b8952d] transition-colors"
                    >
                        Save to Calendar
                    </a>
                    <a
                        href="https://maps.google.com/?q=Masjid+Raya+Al-Muhajirin+Jakarta+Selatan"
                        target="_blank"
                        class="border border-gold text-gold px-6 py-2 rounded-full text-sm font-semibold hover:bg-gold hover:text-white transition-all"
                    >
                        Open Google Maps
                    </a>
                </div>
            </div>

            <!-- Resepsi -->
            <div
                class="p-8 bg-white shadow-xl rounded-lg border border-gold/20"
            >
                <h3 class="font-serif text-3xl text-gold mb-4 italic">
                    Resepsi
                </h3>
                <p class="text-gray-600 mb-2">Minggu, 12 Desember 2026</p>
                <p
                    class="text-gray-600 mb-4 font-semibold uppercase tracking-widest"
                >
                    11:00 - 14:00 WIB
                </p>
                <p class="text-gray-800 font-serif italic mb-8">
                    Grand Ballroom Hotel <br /> Jakarta Selatan
                </p>

                <div class="flex flex-col gap-4">
                    <a
                        href={`https://calendar.google.com/calendar/render?action=TEMPLATE&text=Resepsi+${groom.name}+%26+${bride.name}&dates=20261212T040000Z/20261212T070000Z&details=Resepsi+${groom.name}+and+${bride.name}&location=Grand+Ballroom+Hotel`}
                        target="_blank"
                        class="bg-gold text-white px-6 py-2 rounded-full text-sm font-semibold hover:bg-[#b8952d] transition-colors"
                    >
                        Save to Calendar
                    </a>
                    <a
                        href="https://maps.google.com/?q=Grand+Ballroom+Hotel+Jakarta+Selatan"
                        target="_blank"
                        class="border border-gold text-gold px-6 py-2 rounded-full text-sm font-semibold hover:bg-gold hover:text-white transition-all"
                    >
                        Open Google Maps
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
