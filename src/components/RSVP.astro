---
/* 
   MODIFIKASI RSVP:
   - Sesuaikan placeholder input.
   - Ubah logika pengiriman form (misal ke WhatsApp atau Database).
*/
---

<section id="rsvp" class="py-20 bg-blush px-4">
    <div
        class="max-w-2xl mx-auto bg-white p-10 rounded-2xl shadow-2xl border border-gold/10"
    >
        <h2 class="font-serif text-4xl text-gold text-center mb-10 italic">
            Buku Tamu
        </h2>
        <p class="text-center text-gray-600 mb-12">
            Mohon konfirmasi kehadiran Anda melalui form di bawah ini.
        </p>

        <div id="rsvp-container" class="relative">
            <!-- Form RSVP -->
            <form id="rsvp-form" class="space-y-6 transition-all duration-500">
                <div>
                    <label
                        for="rsvp-name"
                        class="block text-sm font-medium text-gray-700 mb-2"
                        >Nama Lengkap</label
                    >
                    <input
                        type="text"
                        id="rsvp-name"
                        name="name"
                        placeholder="Contoh: Budi Santoso"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all"
                        required
                    />
                </div>

                <div>
                    <label
                        for="rsvp-guests"
                        class="block text-sm font-medium text-gray-700 mb-2"
                        >Jumlah Tamu</label
                    >
                    <select
                        id="rsvp-guests"
                        name="guests"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-transparent outline-none transition-all"
                    >
                        <option value="1">1 Orang</option>
                        <option value="2">2 Orang</option>
                        <option value="3">3 Orang</option>
                        <option value="4">4 Orang</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-4"
                        >Konfirmasi Kehadiran</label
                    >
                    <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
                        <label
                            class="flex items-center gap-2 cursor-pointer p-3 border border-gray-200 rounded-xl hover:border-gold hover:bg-gold/5 transition-all w-full"
                        >
                            <input
                                type="radio"
                                name="attendance"
                                value="hadir"
                                class="w-4 h-4 text-gold border-gray-300 focus:ring-gold"
                                checked
                            />
                            <span class="text-gray-700 text-sm"
                                >Saya akan hadir</span
                            >
                        </label>
                        <label
                            class="flex items-center gap-2 cursor-pointer p-3 border border-gray-200 rounded-xl hover:border-gold hover:bg-gold/5 transition-all w-full"
                        >
                            <input
                                type="radio"
                                name="attendance"
                                value="tidak-hadir"
                                class="w-4 h-4 text-gold border-gray-300 focus:ring-gold"
                            />
                            <span class="text-gray-700 text-sm"
                                >Maaf, tidak bisa hadir</span
                            >
                        </label>
                    </div>
                </div>

                <div class="pt-6">
                    <button
                        type="submit"
                        id="rsvp-submit"
                        class="w-full bg-gold text-white py-4 rounded-full font-bold uppercase tracking-widest hover:bg-[#b8952d] transition-all shadow-lg active:scale-95"
                    >
                        Kirim Konfirmasi
                    </button>
                </div>
            </form>

            <!-- Pesan Sukses (Hidden by default) -->
            <div id="rsvp-success" class="hidden text-center py-10">
                <div
                    class="w-20 h-20 bg-gold/10 text-gold rounded-full flex items-center justify-center mx-auto mb-6"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-10 w-10"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="3"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-serif text-gray-800 mb-2">
                    Terima Kasih!
                </h3>
                <p class="text-gray-600 mb-8">
                    Konfirmasi kehadiran Anda telah kami terima.
                </p>
                <!-- Tombol untuk mereset/mengirim lagi -->
                <button
                    id="rsvp-reset"
                    class="text-gold font-semibold hover:underline"
                >
                    Kirim konfirmasi lainnya
                </button>
            </div>
        </div>

        <!-- Area Tampilan Daftar RSVP (Dinamis) -->
        <div class="mt-16 border-t border-gold/10 pt-10">
            <h3 class="font-serif text-2xl text-gold text-center mb-6 italic">
                Daftar Kehadiran
            </h3>
            <div
                id="rsvp-list-container"
                class="grid grid-cols-1 sm:grid-cols-2 gap-4"
            >
                <!-- Pesan akan dimunculkan di sini lewat JavaScript -->
                <div
                    class="col-span-full text-center py-6 text-gray-400 italic"
                >
                    Memuat daftar kehadiran...
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // --- LOGIKA RSVP AJAX (TANPA RELOAD) ---

    // SETINGAN SUPABASE
    // Ubah ke true untuk mengaktifkan database Supabase
    // Ubah ke false untuk hanya menggunakan localStorage (mode demo)
    const useSupabase = true;

    import { supabase } from "../lib/supabase.js";

    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("rsvp-form") as HTMLFormElement;
        const container = document.getElementById("rsvp-success");
        const resetBtn = document.getElementById("rsvp-reset");
        const rsvpListContainer = document.getElementById(
            "rsvp-list-container",
        );

        if (!form || !container) return;

        // Fungsi ambil data RSVP
        async function getRSVPs() {
            if (useSupabase) {
                try {
                    const { data, error } = await supabase
                        .from("rsvp")
                        .select("*")
                        .order("created_at", { ascending: false });

                    if (error) {
                        console.error("Supabase Error Code:", error.code);
                        console.error("Supabase Error Message:", error.message);
                        throw error;
                    }
                    console.log("Supabase RSVP Data fetched:", data);
                    return data || [];
                } catch (error) {
                    console.error("Error fetching RSVPs from Supabase:", error);
                    return [];
                }
            } else {
                const saved = localStorage.getItem("wedding_rsvp");
                return saved ? JSON.parse(saved) : [];
            }
        }

        // Fungsi render RSVP list
        async function renderRSVPs() {
            if (!rsvpListContainer) return;
            const rsvps = await getRSVPs();

            if (rsvps.length === 0) {
                rsvpListContainer.innerHTML =
                    '<div class="col-span-full text-center py-6 text-gray-400 italic">Belum ada konfirmasi kehadiran.</div>';
                return;
            }

            rsvpListContainer.innerHTML = rsvps
                .map((r: any) => {
                    const name = r.nama || r.name || "Anonim";
                    const isPresent =
                        r.kehadiran === true || r.attendance === "hadir";
                    const guests = r.jumlah_orang || r.guests || 1;

                    return `
                        <div class="bg-gray-50 p-4 rounded-xl border-l-4 ${isPresent ? "border-green-400" : "border-red-400"} flex items-center justify-between">
                            <div>
                                <h4 class="font-bold text-gray-800">${name}</h4>
                                <p class="text-xs text-gray-500">${isPresent ? "Berencana Hadir" : "Maaf, Tidak Bisa Hadir"}</p>
                            </div>
                            <div class="text-right">
                                <span class="bg-gold/10 text-gold text-xs font-bold px-2 py-1 rounded-full">${guests} Orang</span>
                            </div>
                        </div>
                    `;
                })
                .join("");
        }

        // Jalankan render awal
        renderRSVPs();

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            // 1. Ambil Data
            const formData = new FormData(form);
            const attendanceValue = formData.get("attendance");
            const isPresent = attendanceValue === "hadir";
            const guestsCount = parseInt(formData.get("guests") as string);

            const data = {
                nama: formData.get("name"),
                jumlah_orang: guestsCount,
                kehadiran: isPresent,
            };

            // 2. Efek Loading
            const submitBtn = document.getElementById("rsvp-submit");
            if (submitBtn) {
                submitBtn.innerHTML =
                    '<span class="animate-pulse">Mengirim...</span>';
                submitBtn.setAttribute("disabled", "true");
            }

            try {
                if (useSupabase) {
                    // Simpan ke Supabase
                    const { error } = await supabase
                        .from("rsvp")
                        .insert([data]);

                    if (error) {
                        console.error("Supabase Submission Error:", error);
                        throw error;
                    }

                    // Trigger render ulang setelah simpan
                    renderRSVPs();
                } else {
                    // Simpan ke LocalStorage (Mock Database) sebagai fallback
                    const existingRsvp = JSON.parse(
                        localStorage.getItem("wedding_rsvp") || "[]",
                    );
                    existingRsvp.push({
                        ...data,
                        id: Date.now(),
                        time: new Date().toISOString(),
                    });
                    localStorage.setItem(
                        "wedding_rsvp",
                        JSON.stringify(existingRsvp),
                    );
                    renderRSVPs();
                }

                // 3. Tampilkan Pesan Sukses
                setTimeout(() => {
                    form.classList.add(
                        "opacity-0",
                        "pointer-events-none",
                        "absolute",
                    );
                    setTimeout(() => {
                        form.classList.add("hidden");
                        container.classList.remove("hidden");
                        container.classList.add("block");
                    }, 300);
                }, 500);
            } catch (error) {
                console.error("Error submitting RSVP:", error);
                alert(
                    "Maaf, terjadi kesalahan saat mengirim konfirmasi. Silakan coba lagi. Pastikan koneksi internet aktif.",
                );

                if (submitBtn) {
                    submitBtn.innerHTML = "Kirim Konfirmasi";
                    submitBtn.removeAttribute("disabled");
                }
            }
        });

        // Tombol untuk mereset/mengirim lagi
        resetBtn?.addEventListener("click", () => {
            container.classList.add("hidden");
            form.classList.remove(
                "hidden",
                "opacity-0",
                "pointer-events-none",
                "absolute",
            );
            form.reset();
            const submitBtn = document.getElementById("rsvp-submit");
            if (submitBtn) {
                submitBtn.innerHTML = "Kirim Konfirmasi";
                submitBtn.removeAttribute("disabled");
            }
        });

        // Realtime Supabase untuk RSVP
        if (useSupabase) {
            supabase
                .channel("rsvp-realtime")
                .on(
                    "postgres_changes",
                    { event: "INSERT", schema: "public", table: "rsvp" },
                    () => {
                        renderRSVPs();
                    },
                )
                .subscribe();
        }
    });
</script>
