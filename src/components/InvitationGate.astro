---
/* 
   -----------------------------------------------------------
   INVITATION GATE (MODAL PEMBUKA)
   -----------------------------------------------------------
   PENGATURAN UTAMA:
*/

// [!] GANTI EFEK DI SINI: 'door', 'slide-up', 'fade', 'fade-blur'
const OPENING_EFFECT = "slide-up";

// 1. DATA PENGANTIN (Diterima dari props index.astro)
interface Props {
    groom: string;
    bride: string;
}

const { groom, bride } = Astro.props;

const GATE_DATA = {
    groom: groom || "Umar",
    bride: bride || "Nazwa",
    gateBg: "/assets/bg-hero.jpg",
};

// 2. PENGATURAN TAMPILAN MODAL
const GATE_UI = {
    // 1. Efek Pembukaan (Diwarisi dari variabel OPENING_EFFECT di atas)
    openingEffect: OPENING_EFFECT,

    // 2. Bentuk Modal: 'rounded', 'square', 'arch'
    modalShape: "rounded",
    modalWidth: "max-w-md",

    // 3. Jarak (Padding)
    paddingAtas: "12",
    paddingBawah: "12",
    paddingKiri: "2",
    paddingKanan: "2",
    marginKonten: "4",

    // 4. Efek Visual Modal
    backgroundOpacity: "0.98",
    enableBlur: true,
    blurAmount: "10px",

    // 5. Fitur Tambahan
    enableMusic: true,
    lockScroll: true,
};
---

<!-- MUSIK LATAR -->{
    GATE_UI.enableMusic && (
        <audio id="bg-music" loop preload="none">
            <source src="/sound/janjisuci.mp3" type="audio/mpeg" />
        </audio>
    )
}

<div
    id="invitation-gate"
    class="fixed inset-0 z-[100] flex items-center justify-center overflow-hidden px-4"
>
    <!-- Background Layers -->
    <div
        id="gate-bg-single"
        class="absolute inset-0 bg-cover bg-center transition-all duration-1000 z-0"
        style={`background-image: url('${GATE_DATA.gateBg}')`}
    >
        <div class="absolute inset-0 bg-white/10"></div>
    </div>

    <div
        id="panel-left"
        class="absolute inset-y-0 left-0 w-1/2 bg-cover bg-no-repeat transition-transform duration-1200 ease-in-out z-10 hidden"
        style={`background-image: url('${GATE_DATA.gateBg}'); background-position: left; background-size: 200% 100%;`}
    >
        <div class="absolute inset-0 bg-white/10"></div>
    </div>
    <div
        id="panel-right"
        class="absolute inset-y-0 right-0 w-1/2 bg-cover bg-no-repeat transition-transform duration-1200 ease-in-out z-10 hidden"
        style={`background-image: url('${GATE_DATA.gateBg}'); background-position: right; background-size: 200% 100%;`}
    >
        <div class="absolute inset-0 bg-white/10"></div>
    </div>

    <!-- Konten Modal (Gate Card) -->
    <div
        id="gate-card"
        class={`relative z-20 text-center glass-card shadow-2xl transition-all duration-1000 w-full ${GATE_UI.modalWidth} shape-${GATE_UI.modalShape}`}
        style={{
            paddingTop: `${Number(GATE_UI.paddingAtas) * 0.25}rem`,
            paddingBottom: `${Number(GATE_UI.paddingBawah) * 0.25}rem`,
            paddingLeft: `${Number(GATE_UI.paddingKiri) * 0.25}rem`,
            paddingRight: `${Number(GATE_UI.paddingKanan) * 0.25}rem`,
            margin: `${Number(GATE_UI.marginKonten) * 0.25}rem`,
            "--bg-opacity": GATE_UI.backgroundOpacity,
            "--bg-blur": GATE_UI.enableBlur ? GATE_UI.blurAmount : "0px",
        } as any}
    >
        <div class="space-y-6">
            <h2
                class="font-serif text-2xl md:text-3xl text-gold italic animate-fade-up"
            >
                The Wedding of
            </h2>
            <h1
                class="font-serif text-5xl md:text-7xl text-[#222] leading-tight animate-fade-up delay-200"
            >
                {GATE_DATA.groom}
                <br /> & <br />
                {GATE_DATA.bride}
            </h1>
            <div class="w-16 h-[1px] bg-gold/30 mx-auto"></div>
            <div class="animate-fade-up delay-500">
                <p class="text-gray-600 tracking-widest text-sm uppercase mb-2">
                    Kepada Bapak/Ibu/Saudara/i,
                </p>
                <p class="text-[#333] font-serif italic text-xl">
                    Kami Mengundang Anda
                </p>
            </div>
            <button
                id="btn-open-invitation"
                class="mt-8 px-10 py-3 bg-gold text-white rounded-full font-bold uppercase tracking-widest transition-all shadow-xl shadow-black/30 animate-fade-up delay-700 btn-hover-premium"
            >
                Buka Undangan
            </button>
        </div>
    </div>
</div>

<style>
    /* CSS Glassmorphism & Shapes */
    .glass-card {
        background: rgba(255, 255, 255, var(--bg-opacity, 0.8));
        backdrop-filter: blur(var(--bg-blur, 10px));
        -webkit-backdrop-filter: blur(var(--bg-blur, 10px));
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.2);
    }
    .shape-rounded {
        border-radius: 2.5rem;
    }
    .shape-square {
        border-radius: 0;
    }
    .shape-arch {
        border-radius: 20rem 20rem 2rem 2rem;
        padding-top: 10rem !important;
    }

    /* Button Hover Effect */
    .btn-hover-premium {
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .btn-hover-premium:hover {
        background-color: #b8952d;
        transform: scale(1.15);
        box-shadow: 0 20px 40px rgba(212, 175, 55, 0.5);
    }
    .btn-hover-premium:active {
        transform: scale(0.95);
    }
    .btn-hover-premium::after {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(
            45deg,
            transparent,
            rgba(255, 255, 255, 0.2),
            transparent
        );
        transform: rotate(45deg);
        transition: 0.5s;
        opacity: 0;
    }
    .btn-hover-premium:hover::after {
        left: 100%;
        top: 100%;
        opacity: 1;
    }

    /* Basic Fade Animation */
    .animate-fade-up {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeUp 1s ease-out forwards;
    }
    .delay-200 {
        animation-delay: 0.2s;
    }
    .delay-500 {
        animation-delay: 0.5s;
    }
    .delay-700 {
        animation-delay: 0.7s;
    }
    @keyframes fadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* OPENING EFFECTS */
    .effect-slide-up {
        transform: translateY(-100%);
        opacity: 0;
    }
    .effect-fade {
        opacity: 0;
    }
    .effect-fade-blur {
        opacity: 0;
        filter: blur(20px);
    }
    .door-left-open {
        transform: translateX(-100%);
    }
    .door-right-open {
        transform: translateX(100%);
    }

    /* PENGUNCI SCROLL TOTAL (Solid) */
    :global(html.lock-scroll),
    :global(body.lock-scroll) {
        overflow: hidden !important;
        height: 100vh !important;
        position: fixed !important;
        width: 100% !important;
    }
</style>

<script define:vars={{ GATE_UI }}>
    const gate = document.getElementById("invitation-gate");
    const openBtn = document.getElementById("btn-open-invitation");
    const music = document.getElementById("bg-music");
    const gateCard = document.getElementById("gate-card");
    const bgSingle = document.getElementById("gate-bg-single");
    const pLeft = document.getElementById("panel-left");
    const pRight = document.getElementById("panel-right");

    const effect = GATE_UI.openingEffect;

    // Inisialisasi Door Panels
    if (effect === "door") {
        bgSingle.style.display = "none";
        pLeft.classList.remove("hidden");
        pRight.classList.remove("hidden");
    }

    // Fungsi Pengunci Scroll
    function setScrollLock(locked) {
        if (GATE_UI.lockScroll) {
            if (locked) {
                document.documentElement.classList.add("lock-scroll");
                document.body.classList.add("lock-scroll");
            } else {
                document.documentElement.classList.remove("lock-scroll");
                document.body.classList.remove("lock-scroll");
            }
        }
    }

    // Cek Status Awal
    const isOpened = sessionStorage.getItem("invitation_status") === "opened";
    if (isOpened) {
        gate.style.display = "none";
        setScrollLock(false);
    } else {
        setScrollLock(true);
    }

    openBtn?.addEventListener("click", () => {
        sessionStorage.setItem("invitation_status", "opened");
        if (music) music.play().catch(() => {});

        // Lepas kunci scroll saat terbuka
        setScrollLock(false);

        // Emit event agar Hero tahu kapan harus Reveal
        window.dispatchEvent(new Event("invitationOpened"));

        runOpeningEffect();
    });

    function runOpeningEffect() {
        if (effect === "slide-up") {
            gate.classList.add(
                "transition-all",
                "duration-1000",
                "effect-slide-up",
            );
            setTimeout(() => {
                gate.style.display = "none";
            }, 1000);
        } else if (effect === "door") {
            gateCard.classList.add("opacity-0", "scale-90");
            setTimeout(() => {
                pLeft.classList.add("door-left-open");
                pRight.classList.add("door-right-open");
                setTimeout(() => {
                    gate.style.display = "none";
                }, 1200);
            }, 300);
        } else {
            gateCard.classList.add("opacity-0", "scale-90");
            gate.classList.add(
                "transition-all",
                "duration-1000",
                effect === "fade-blur" ? "effect-fade-blur" : "effect-fade",
            );
            setTimeout(() => {
                gate.style.display = "none";
            }, 1000);
        }
    }
</script>
