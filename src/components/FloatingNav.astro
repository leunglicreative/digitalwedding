---
/**
 * Komponen Floating Navigation
 * Berisi tombol "Back to Top" dan Kontrol Musik (Play/Pause)
 */

// Togle Fitur Utama (Bisa dimatikan di sini)
const ENABLE_FLOATING_NAV = true; // true = Tampilkan Navigasi Melayang
const ENABLE_MUSIC_CONTROL = true; // true = Tampilkan tombol musik (jika musik aktif di Hero)
---

{
    ENABLE_FLOATING_NAV && (
        <div
            id="floating-nav"
            class="fixed bottom-4 right-4 md:bottom-8 md:right-8 z-[999] flex flex-col gap-3 md:gap-4 transition-all duration-500 translate-x-20 opacity-0"
            style="will-change: transform, opacity;"
        >
            {/* Tombol Kontrol Musik */}
            {ENABLE_MUSIC_CONTROL && (
                <button
                    id="music-toggle-btn"
                    class="w-10 h-10 md:w-12 md:h-12 bg-white/90 backdrop-blur-md border border-gold/30 rounded-full flex items-center justify-center text-gold shadow-lg hover:scale-110 active:scale-95 transition-all group hidden"
                    style="will-change: transform;"
                    title="Play/Pause Music"
                >
                    {/* Icon Play */}
                    <svg
                        id="icon-play"
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 md:h-6 md:w-6 hidden"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                        />
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                    </svg>
                    {/* Icon Pause */}
                    <svg
                        id="icon-pause"
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 md:h-6 md:w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                    </svg>
                </button>
            )}

            {/* Tombol Back to Top */}
            <button
                id="back-to-top"
                class="w-10 h-10 md:w-12 md:h-12 bg-gold text-white rounded-full flex items-center justify-center shadow-lg hover:bg-gold/80 hover:scale-110 active:scale-95 transition-all"
                title="Kembali ke Atas"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 md:h-6 md:w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 10l7-7m0 0l7 7m-7-7v18"
                    />
                </svg>
            </button>
        </div>
    )
}

<script>
    // --- LOGIKA FLOATING NAV ---
    const nav = document.getElementById("floating-nav");
    const backToTopBtn = document.getElementById("back-to-top");
    const musicBtn = document.getElementById("music-toggle-btn");
    const iconPlay = document.getElementById("icon-play");
    const iconPause = document.getElementById("icon-pause");

    // Gunakan interval singkat untuk memastikan element audio sudah ter-render
    // karena Audio element biasanya ada di component Hero yang berbeda.
    let checkMusicInterval = setInterval(() => {
        const bgMusic = document.getElementById("bg-music") as HTMLAudioElement;

        if (bgMusic && musicBtn) {
            clearInterval(checkMusicInterval);
            initMusicControl(bgMusic);
        }
    }, 500);

    // Timeout setelah 5 detik jika tidak ketemu (mungkin fitur musik dimatikan)
    setTimeout(() => clearInterval(checkMusicInterval), 5000);

    function initMusicControl(bgMusic: HTMLAudioElement) {
        if (!musicBtn) return;

        // Tampilkan tombol musik jika element audio ada
        musicBtn.classList.remove("hidden");

        musicBtn.addEventListener("click", () => {
            if (bgMusic.paused) {
                bgMusic.play().catch((e) => console.log("Playback blocked"));
            } else {
                bgMusic.pause();
            }
        });

        // Sync icon jika musik berubah status
        const updateIcons = () => {
            if (bgMusic.paused) {
                iconPlay?.classList.remove("hidden");
                iconPause?.classList.add("hidden");
            } else {
                iconPlay?.classList.add("hidden");
                iconPause?.classList.remove("hidden");
            }
        };

        bgMusic.addEventListener("play", updateIcons);
        bgMusic.addEventListener("pause", updateIcons);
        updateIcons(); // Init state
    }

    // 1. TAMPILKAN NAV SAAT SCROLL (Muncul setelah scroll 300px)
    window.addEventListener("scroll", () => {
        if (window.scrollY > 300) {
            nav?.classList.remove("translate-x-20", "opacity-0");
        } else {
            nav?.classList.add("translate-x-20", "opacity-0");
        }
    });

    // 2. BACK TO TOP SMOOTH SCROLL
    backToTopBtn?.addEventListener("click", () => {
        window.scrollTo({
            top: 0,
            behavior: "smooth",
        });
    });
</script>
