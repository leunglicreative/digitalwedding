---
/**
 * KONFIGURASI WISHES (PAGINATION)
 * - Bagian ini menggunakan localStorage untuk menyimpan pesan sementara.
 * - Pagination diatur untuk menampilkan 2 pesan per halaman.
 */
---

<section id="wish" class="py-20 bg-soft-white px-4">
    <div class="max-w-4xl mx-auto">
        <h2 class="font-serif text-4xl text-gold text-center mb-16 italic">
            Best Wishes
        </h2>

        <!-- Form Pengiriman Pesan -->
        <div
            class="bg-white p-8 rounded-2xl shadow-xl border border-gold/10 mb-12"
        >
            <form id="wish-form" class="space-y-4">
                <div>
                    <input
                        type="text"
                        id="wish-name"
                        placeholder="Nama Anda"
                        required
                        class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-gold outline-none transition-all"
                    />
                </div>
                <div>
                    <textarea
                        id="wish-message"
                        rows="4"
                        placeholder="Tulis ucapan & doa restu..."
                        required
                        class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-gold outline-none transition-all"
                    ></textarea>
                </div>
                <button
                    type="submit"
                    class="w-full md:w-auto bg-gold text-white px-10 py-3 rounded-full font-bold uppercase tracking-widest hover:bg-[#b8952d] hover:shadow-lg active:scale-95 transition-all"
                >
                    Kirim Ucapan
                </button>
            </form>

            <!-- Pesan Sukses - Ditampilkan setelah berhasil mengirim -->
            <div
                id="wish-success-msg"
                class="hidden mt-4 p-4 bg-green-50 text-green-700 rounded-lg border border-green-200 text-center font-medium"
            >
                <div class="flex items-center justify-center gap-2">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"></path>
                    </svg>
                    Terima kasih atas ucapan dan doa restunya!
                </div>
            </div>
        </div>

        <!-- Area Tampilan Daftar Ucapan (Dinamis) -->
        <div id="wishes-container" class="space-y-6">
            <!-- Pesan akan dimunculkan di sini lewat JavaScript -->
            <div class="text-center py-10 text-gray-400 italic">
                Belum ada ucapan. Jadilah yang pertama memberikan doa!
            </div>
        </div>

        <!-- Navigasi Pagination -->
        <div
            id="wish-pagination"
            class="justify-center items-center gap-2 mt-12 hidden"
        >
            <button
                id="prev-page"
                class="p-2 border border-gold text-gold rounded-full hover:bg-gold hover:text-white transition-all disabled:opacity-30 disabled:pointer-events-none"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
            </button>

            <div id="page-numbers" class="flex gap-2">
                <!-- Angka halaman akan muncul di sini -->
            </div>

            <button
                id="next-page"
                class="p-2 border border-gold text-gold rounded-full hover:bg-gold hover:text-white transition-all disabled:opacity-30 disabled:pointer-events-none"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"></path>
                </svg>
            </button>
        </div>
    </div>
</section>

<script>
    // --- LOGIKA WISHES & PAGINATION ---

    // SETINGAN SUPABASE
    // Ubah ke true untuk mengaktifkan database Supabase
    // Ubah ke false untuk hanya menggunakan localStorage (mode demo)
    const useSupabase = true;

    import { supabase } from "../lib/supabase.js";

    // 1. Inisialisasi Data
    const ITEMS_PER_PAGE = 5; // Tampilkan 5 pesan per halaman
    let currentPage = 1;

    const form = document.getElementById("wish-form") as HTMLFormElement;
    const container = document.getElementById("wishes-container");
    const pagination = document.getElementById("wish-pagination");
    const pageNumbers = document.getElementById("page-numbers");
    const prevBtn = document.getElementById("prev-page") as HTMLButtonElement;
    const nextBtn = document.getElementById("next-page") as HTMLButtonElement;
    const successMsg = document.getElementById("wish-success-msg");

    // 2. Fungsi Ambil Data (Supabase atau LocalStorage)
    // Fungsi ini akan mengambil data doa/ucapan dari database atau storage lokal
    async function getWishes() {
        if (useSupabase) {
            try {
                const { data, error } = await supabase
                    .from("wish")
                    .select("*")
                    .order("created_at", { ascending: false });

                if (error) throw error;
                return data || [];
            } catch (error) {
                console.error("Error fetching wishes from Supabase:", error);
                return [];
            }
        } else {
            // Mode fallback menggunakan localStorage jika tidak memakai database
            const saved = localStorage.getItem("wedding_wishes");
            const wishes = saved ? JSON.parse(saved) : [];
            // Pastikan diurutkan terbaru (berdasarkan id/timestamp jika tidak ada created_at)
            return wishes.sort((a: any, b: any) => (b.id || 0) - (a.id || 0));
        }
    }

    // 3. Fungsi Render Wishes
    async function renderWishes() {
        const allWishes = await getWishes();
        if (!container) return;

        if (allWishes.length === 0) {
            container.innerHTML =
                '<div class="text-center py-10 text-gray-400 italic">Belum ada ucapan. Jadilah yang pertama memberikan doa!</div>';
            pagination?.classList.add("hidden");
            return;
        }

        // Hitung total halaman
        const totalPages = Math.ceil(allWishes.length / ITEMS_PER_PAGE);

        // Validasi halaman aktif
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;

        const start = (currentPage - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const currentWishes = allWishes.slice(start, end);

        // Render Cards
        container.innerHTML = currentWishes
            .map((w: any) => {
                // Handle format data yang berbeda antara Supabase dan LocalStorage
                const name = w.nama || w.name || "Anonim";
                const message = w.pesan || w.message || "";
                // Gunakan created_at dari database untuk sinkronisasi waktu nyata
                const wishDate = w.created_at
                    ? new Date(w.created_at)
                    : w.time
                      ? new Date(w.time)
                      : new Date(w.id);

                const formattedTime = wishDate.toLocaleString("id-ID", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                });

                return `
            <div class="bg-white p-6 rounded-xl shadow-md border-l-4 border-gold">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center text-gold font-bold flex-shrink-0">
                        ${name.charAt(0).toUpperCase()}
                    </div>
                    <div class="min-w-0 flex-1">
                        <h4 class="font-bold text-gray-800 leading-none truncate">${name}</h4>
                        <span class="text-[10px] text-gray-400">${formattedTime}</span>
                    </div>
                </div>
                <p class="text-gray-600 italic leading-relaxed break-words">
                    "${message}"
                </p>
            </div>
        `;
            })
            .join("");

        // Tampilkan/Sembunyikan Navigasi Pagination
        if (allWishes.length > ITEMS_PER_PAGE) {
            pagination?.classList.remove("hidden");
            pagination?.classList.add("flex");
            updatePaginationUI(totalPages);
        } else {
            pagination?.classList.add("hidden");
            pagination?.classList.remove("flex");
        }
    }

    // 4. Update UI Pagination (Tombol & Angka)
    function updatePaginationUI(totalPages: number) {
        if (!pageNumbers || !prevBtn || !nextBtn) return;

        // Render angka halaman
        pageNumbers.innerHTML = "";

        for (let i = 1; i <= totalPages; i++) {
            const btn = document.createElement("button");
            btn.innerText = i.toString();
            btn.className = `w-10 h-10 rounded-full border border-gold/30 flex items-center justify-center transition-all ${i === currentPage ? "bg-gold text-white font-bold" : "text-gold hover:bg-gold/10"}`;
            btn.onclick = () => {
                currentPage = i;
                renderWishes();
                scrollToWishes();
            };
            pageNumbers.appendChild(btn);
        }

        // Set state tombol Navigasi
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages;
    }

    // 5. Scroll Smooth ke area Wishes
    function scrollToWishes() {
        if (!container) return;
        const offset = 100;
        const elementPosition = container.getBoundingClientRect().top;
        const offsetPosition = elementPosition + window.pageYOffset - offset;

        window.scrollTo({
            top: offsetPosition,
            behavior: "smooth",
        });
    }

    // 6. Event Handler Form Submit
    // Logika saat user menekan tombol "Kirim Ucapan"
    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const nameInput = document.getElementById(
            "wish-name",
        ) as HTMLInputElement;
        const msgInput = document.getElementById(
            "wish-message",
        ) as HTMLTextAreaElement;

        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) {
            submitBtn.innerHTML =
                '<span class="animate-pulse">Mengirim...</span>';
            submitBtn.setAttribute("disabled", "true");
        }

        try {
            if (useSupabase) {
                const { error } = await supabase
                    .from("wish")
                    .insert([{ nama: nameInput.value, pesan: msgInput.value }]);

                if (error) throw error;
                // Jangan panggil renderWishes secara manual jika Realtime aktif
                // karena subscription akan menanganinya
            } else {
                const newWish = {
                    id: Date.now(),
                    name: nameInput.value,
                    message: msgInput.value,
                    time: new Date().toISOString(),
                };

                const currentWishes = JSON.parse(
                    localStorage.getItem("wedding_wishes") || "[]",
                );
                currentWishes.unshift(newWish); // Tambahkan ke paling atas
                localStorage.setItem(
                    "wedding_wishes",
                    JSON.stringify(currentWishes),
                );

                // Refresh manual untuk localStorage
                currentPage = 1;
                await renderWishes();
            }

            // Reset form dan tampilkan pesan sukses
            form.reset();

            // Tampilkan pesan sukses di UI (Tanpa window.alert)
            if (successMsg) {
                successMsg.classList.remove("hidden");
                // Sembunyikan kembali setelah 5 detik
                setTimeout(() => {
                    successMsg.classList.add("hidden");
                }, 5000);
            }

            // Jika tidak pakai Supabase (LocalStorage), refresh manual
            if (!useSupabase) {
                currentPage = 1;
                await renderWishes();
            }
        } catch (error) {
            console.error("Error submitting wish:", error);
            // Tetap menggunakan alert untuk error agar user tahu ada masalah teknis
            alert(
                "Maaf, terjadi kesalahan saat mengirim ucapan. Silakan coba lagi.",
            );
        } finally {
            if (submitBtn) {
                submitBtn.innerHTML = "Kirim Ucapan";
                submitBtn.removeAttribute("disabled");
            }
        }
    });

    // 7. Event Handler Tombol Prev/Next
    prevBtn?.addEventListener("click", () => {
        if (currentPage > 1) {
            currentPage--;
            renderWishes();
            scrollToWishes();
        }
    });

    nextBtn?.addEventListener("click", async () => {
        const all = await getWishes();
        const maxPage = Math.ceil(all.length / ITEMS_PER_PAGE);
        if (currentPage < maxPage) {
            currentPage++;
            renderWishes();
            scrollToWishes();
        }
    });

    // 8. Logika Realtime Supabase
    // Menggunakan fitur Realtime Supabase agar daftar ucapan langsung update otomatis
    function setupRealtime() {
        if (!useSupabase) return;

        // Berlangganan perubahan pada tabel 'wish'
        supabase
            .channel("wish-realtime")
            .on(
                "postgres_changes",
                { event: "INSERT", schema: "public", table: "wish" },
                (payload) => {
                    console.log("Wish baru diterima secara realtime!", payload);
                    // Jika user sedang di halaman pertama, langsung refresh
                    // Jika tidak, biarkan saja (user bisa klik angka 1 nanti)
                    if (currentPage === 1) {
                        renderWishes();
                    }
                },
            )
            .subscribe();
    }

    // Jalankan awal
    document.addEventListener("DOMContentLoaded", () => {
        renderWishes();
        setupRealtime();
    });
</script>
