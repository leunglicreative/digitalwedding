---
/* 
   MODIFIKASI COUNTDOWN:
   - Ganti variabel 'targetDate' di dalam <script> dengan tanggal pernikahan Anda.
   - Edit label (Hari, Jam, dsb) jika ingin menggunakan bahasa lain.
*/
---

<section id="countdown" class="pt-12 pb-1 bg-blush px-4">
    <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-4xl text-gold mb-8 italic">
            Counting Down to the Big Day
        </h2>

        <div id="timer" class="flex justify-center gap-2 md:gap-8 reveal">
            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                >
                    <span
                        id="days"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Hari</span
                >
            </div>

            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                >
                    <span
                        id="hours"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Jam</span
                >
            </div>

            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                >
                    <span
                        id="minutes"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Menit</span
                >
            </div>

            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                >
                    <span
                        id="seconds"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Detik</span
                >
            </div>
        </div>
    </div>
</section>

<script>
    // Tentukan tanggal target di sini (Format: YYYY-MM-DDTHH:MM:SS)
    const targetDate = new Date("2026-12-12T08:00:00").getTime();

    function updateCountdown() {
        const now = new Date().getTime();
        const distance = targetDate - now;

        if (distance < 0) {
            clearInterval(timerInterval);
            return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
            (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById("days").innerText = days
            .toString()
            .padStart(2, "0");
        document.getElementById("hours").innerText = hours
            .toString()
            .padStart(2, "0");
        document.getElementById("minutes").innerText = minutes
            .toString()
            .padStart(2, "0");
        document.getElementById("seconds").innerText = seconds
            .toString()
            .padStart(2, "0");
    }

    const timerInterval = setInterval(updateCountdown, 1000);
    updateCountdown();
</script>
