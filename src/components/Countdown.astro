---
/* 
   MODIFIKASI COUNTDOWN:
   - Ganti variabel 'targetDate' di dalam <script> dengan tanggal pernikahan Anda.
   - Edit label (Hari, Jam, dsb) jika ingin menggunakan bahasa lain.
*/
---

<section id="countdown" class="pt-12 pb-1 bg-blush px-4">
    <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-4xl text-gold mb-8 italic">
            Counting Down to the Big Day
        </h2>

        <div id="timer" class="flex justify-center gap-2 md:gap-8">
            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                    style="backface-visibility: hidden; transform: translateZ(0);"
                >
                    <span
                        id="days"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Hari</span
                >
            </div>

            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                    style="backface-visibility: hidden; transform: translateZ(0);"
                >
                    <span
                        id="hours"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Jam</span
                >
            </div>

            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                    style="backface-visibility: hidden; transform: translateZ(0);"
                >
                    <span
                        id="minutes"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Menit</span
                >
            </div>

            <div class="flex flex-col items-center">
                <div
                    class="w-[70px] h-[70px] md:w-24 md:h-24 bg-white rounded-xl shadow-lg flex items-center justify-center mb-2 border border-gold/10"
                    style="backface-visibility: hidden; transform: translateZ(0);"
                >
                    <span
                        id="seconds"
                        class="text-2xl md:text-4xl font-bold text-gold"
                        >00</span
                    >
                </div>
                <span
                    class="text-[10px] md:text-sm uppercase tracking-widest text-gray-500 font-semibold"
                    >Detik</span
                >
            </div>
        </div>
    </div>
</section>

<script>
    // --- KONFIGURASI TANGGAL ---
    // Tentukan tanggal target di sini (Format: YYYY-MM-DDTHH:MM:SS)
    // Contoh: "2026-12-12T08:00:00" berarti 12 Desember 2026 jam 08:00 pagi.
    const targetDate = new Date("2026-12-12T08:00:00").getTime();

    // --- LOGIKA HITUNG MUNDUR ---
    function updateCountdown() {
        // Ambil waktu sekarang
        const now = new Date().getTime();
        // Hitung selisih waktu
        const distance = targetDate - now;

        // Jika waktu sudah lewat, hentikan timer
        if (distance < 0) {
            clearInterval(timerInterval);
            return;
        }

        // Kalkulasi Hari, Jam, Menit, dan Detik
        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
            (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        // Update tampilan ke HTML (dengan padStart agar selalu 2 digit, misal: 01, 09)
        const daysEl = document.getElementById("days");
        const hoursEl = document.getElementById("hours");
        const minutesEl = document.getElementById("minutes");
        const secondsEl = document.getElementById("seconds");

        if (daysEl) daysEl.innerText = days.toString().padStart(2, "0");
        if (hoursEl) hoursEl.innerText = hours.toString().padStart(2, "0");
        if (minutesEl)
            minutesEl.innerText = minutes.toString().padStart(2, "0");
        if (secondsEl)
            secondsEl.innerText = seconds.toString().padStart(2, "0");
    }

    // Jalankan timer setiap 1 detik
    const timerInterval = setInterval(updateCountdown, 1000);
    // Jalankan sekali saat pertama kali load agar tidak menunggu 1 detik
    updateCountdown();
</script>
