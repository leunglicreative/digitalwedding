---
/* 
   REVISI COUPLE SECTION:
   - Menghilangkan modal dan menampilkan biodata langsung dalam container.
   - Menggunakan efek glassmorphism (blur & semi-transparent) untuk container.
   - Desain kotak (rounded rectangle) yang memuat foto dan informasi pasangan.
   - Menggunakan data dari props index.astro.
*/
interface Props {
    groom: {
        name: string;
        parentFather: string;
        parentMother: string;
        image: string;
    };
    bride: {
        name: string;
        parentFather: string;
        parentMother: string;
        image: string;
    };
}

const { groom, bride } = Astro.props;
---

<section id="couple" class="py-20 bg-soft-white text-center px-4">
    <div class="max-w-6xl mx-auto">
        <h2 class="font-serif text-4xl md:text-5xl text-gold mb-12 italic">
            Tentang Kita
        </h2>

        <div class="grid md:grid-cols-2 gap-12 items-stretch">
            <!-- Container Pengantin Pria (Groom) -->
            <div class="glass-container p-8 flex flex-col items-center">
                <div
                    class="w-64 h-64 md:w-56 md:h-56 overflow-hidden mb-6 border-4 border-gold shadow-lg rounded-2xl"
                >
                    <img
                        src={groom.image}
                        alt="Groom"
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover"
                    />
                </div>
                <h3 class="font-serif text-3xl text-gold mb-2">{groom.name}</h3>
                <p class="text-[#333] mb-4 italic leading-relaxed">
                    Putra dari {groom.parentFather} & <br />
                    {groom.parentMother}
                </p>
            </div>

            <!-- Container Pengantin Wanita (Bride) -->
            <div class="glass-container p-8 flex flex-col items-center">
                <div
                    class="w-64 h-64 md:w-56 md:h-56 overflow-hidden mb-6 border-4 border-gold shadow-lg rounded-2xl"
                >
                    <img
                        src={bride.image}
                        alt="Bride"
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover"
                    />
                </div>
                <h3 class="font-serif text-3xl text-gold mb-2">{bride.name}</h3>
                <p class="text-[#333] mb-4 italic leading-relaxed">
                    Putri dari {bride.parentFather} & <br />
                    {bride.parentMother}
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    /* Definisi Warna & Efek Glassmorphism */
    .text-gold {
        color: #d4af37;
    }
    .border-gold {
        border-color: #d4af37;
    }

    .glass-container {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 2rem;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.05);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        will-change: transform, backdrop-filter;
    }

    .glass-container:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.1);
    }
</style>
