---
/* 
   MODIFIKASI COUPLE SECTION:
   - Hubungkan ke link media sosial atau edit biodata.
   - Gunakan font serif untuk nama agar terlihat lebih elegan.
*/
---

<section id="couple" class="py-20 bg-soft-white text-center px-4">
    <div class="max-w-4xl mx-auto animate-fade-in">
        <h2 class="font-serif text-4xl md:text-5xl text-gold mb-12 italic">
            The Happy Couple
        </h2>

        <div class="grid md:grid-cols-2 gap-12 items-center">
            <!-- Pengantin Pria -->
            <div class="flex flex-col items-center">
                <div
                    class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden mb-6 border-4 border-gold shadow-lg"
                >
                    <img
                        src="/assets/foto-groom.JPG"
                        alt="Groom"
                        class="w-full h-full object-cover"
                    />
                </div>
                <h3 class="font-serif text-3xl text-[#333] mb-2">Umar</h3>
                <p class="text-gray-600 mb-4 italic">
                    Putra dari Bapak Lord Montague & <br /> Ibu Lady Montague
                </p>
            </div>

            <!-- Pengantin Wanita -->
            <div class="flex flex-col items-center">
                <div
                    class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden mb-6 border-4 border-gold shadow-lg"
                >
                    <img
                        src="/assets/jun-yi.jpeg"
                        alt="Bride"
                        class="w-full h-full object-cover"
                    />
                </div>
                <h3 class="font-serif text-3xl text-[#333] mb-2">Eliza</h3>
                <p class="text-gray-600 mb-4 italic">
                    Putri dari Bapak Lord Capulet & <br /> Ibu Lady Capulet
                </p>
            </div>
        </div>
    </div>
</section>
