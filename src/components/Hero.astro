---
// /*
//    -----------------------------------------------------------
//    HERO SECTION (MAIN CONTENT)
//    -----------------------------------------------------------
//    - Menampilkan Nama Pengantin Utama.
//    - Countdwon Waktu.
//    - Reveal Animation setelah undangan dibuka.
// */

interface Props {
    groom: { name: string };
    bride: { name: string };
    // // indonesia: Tambahkan prop untuk background hero
    heroBackground?: string;
}

const { groom, bride, heroBackground } = Astro.props;

const HERO_DATA = {
    groom: groom.name || "",
    bride: bride.name || "",
    date: "2026-08-23T08:00:00",
    // // indonesia: Gunakan foto dari props jika ada, jika tidak gunakan default
    mainHeroBg: heroBackground || "",
};
---

<section
    id="hero-main"
    class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#111]"
>
    <!-- Latar Belakang Hero Utama -->
    <div
        id="main-bg"
        class="absolute inset-0 bg-cover bg-center brightness-50 scale-110 transition-all duration-[2.5s]"
        style={`background-image: url('${HERO_DATA.mainHeroBg}')`}
    >
    </div>

    <!-- Detail Konten Hero -->
    <div
        id="hero-content"
        class="relative z-10 text-center text-white opacity-0 translate-y-12 transition-all duration-1000"
    >
        <span class="text-gold uppercase tracking-[0.4em] text-sm block mb-4"
            >You are Invited to the Wedding of</span
        >
        <h1
            class="text-5xl md:text-8xl font-serif mb-6 drop-shadow-xl text-white"
        >
            {HERO_DATA.groom} & {HERO_DATA.bride}
        </h1>
        <p class="max-w-xl mx-auto text-white/80 italic mb-12 px-6">
            "Dan di antara tanda-tanda (kebesaran)-Nya ialah Dia menciptakan
            pasangan-pasangan untukmu dari jenismu sendiri..."
        </p>

        <!-- COUNTDOWN -->
        <div class="flex justify-center gap-6 md:gap-10" id="hero-countdown">
            <div class="text-center group">
                <span
                    id="d-val"
                    class="text-4xl md:text-6xl font-serif block text-white group-hover:text-gold transition-colors"
                    >00</span
                >
                <span class="text-[10px] uppercase tracking-widest text-gold/80"
                    >Hari</span
                >
            </div>
            <div class="text-center group">
                <span
                    id="h-val"
                    class="text-4xl md:text-6xl font-serif block text-white group-hover:text-gold transition-colors"
                    >00</span
                >
                <span class="text-[10px] uppercase tracking-widest text-gold/80"
                    >Jam</span
                >
            </div>
            <div class="text-center group">
                <span
                    id="m-val"
                    class="text-4xl md:text-6xl font-serif block text-white group-hover:text-gold transition-colors"
                    >00</span
                >
                <span class="text-[10px] uppercase tracking-widest text-gold/80"
                    >Menit</span
                >
            </div>
            <div class="text-center group">
                <span
                    id="s-val"
                    class="text-4xl md:text-6xl font-serif block text-white group-hover:text-gold transition-colors"
                    >00</span
                >
                <span class="text-[10px] uppercase tracking-widest text-gold/80"
                    >Detik</span
                >
            </div>
        </div>
    </div>
</section>

<style>
    .text-gold {
        color: #d4af37;
    }
</style>

<script define:vars={{ HERO_DATA }}>
    const mainContent = document.getElementById("hero-content");
    const mainBg = document.getElementById("main-bg");

    // Reveal Logic
    function revealHero(instantly = false) {
        if (instantly) {
            mainContent.style.transition = "none";
            mainBg.style.transition = "none";
        }
        mainContent.classList.remove("opacity-0", "translate-y-12");
        mainBg.style.transform = "scale(1)";
    }

    // Cek di awal
    if (sessionStorage.getItem("invitation_status") === "opened") {
        revealHero(true);
    }

    // Tunggu event dari InvitationGate
    window.addEventListener("invitationOpened", () => {
        setTimeout(() => revealHero(false), 500);
    });

    // Countdown Logic
    const targetTime = new Date(HERO_DATA.date).getTime();
    const updateTime = () => {
        const diff = targetTime - new Date().getTime();
        if (diff <= 0) return;

        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);

        const setVal = (id, val) => {
            const el = document.getElementById(id);
            if (el) el.innerText = val.toString().padStart(2, "0");
        };

        setVal("d-val", d);
        setVal("h-val", h);
        setVal("m-val", m);
        setVal("s-val", s);
    };

    setInterval(updateTime, 1000);
    updateTime();
</script>
