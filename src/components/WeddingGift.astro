---
/**
 * KONFIGURASI WEDDING GIFT
 * - Bagian ini berisi informasi nomor rekening dan alamat pengiriman kado.
 * - Anda dapat mengganti logo bank, nomor rekening, Alamat, dan link Google Maps di sini.
 */

interface Props {
    groom: { name: string };
    bride: { name: string };
}

const { groom, bride } = Astro.props;

// 1. DATA REKENING
const BANK_BCA = {
    logo: "https://upload.wikimedia.org/wikipedia/commons/thumb/5/5c/Bank_Central_Asia.svg/1200px-Bank_Central_Asia.svg.png",
    number: "1234567890",
    owner: groom.name,
};

const BANK_MANDIRI = {
    logo: "https://upload.wikimedia.org/wikipedia/id/thumb/f/fa/Bank_Mandiri_logo.svg/1200px-Bank_Mandiri_logo.svg.png",
    number: "0987654321",
    owner: bride.name,
};

// 2. DATA ALAMAT PENGIRIMAN
const SHIPPING_ADDRESS = {
    title: "Kirim Kado Fisik",
    receiver: `${groom.name} & ${bride.name}`,
    fullAddress: "Antapani, Kota Bandung",
    // Ganti Link Iframe Google Maps di bawah ini (Ambil dari Google Maps -> Share -> Embed a map)
    mapIframe:
        '<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15843.088805640304!2d107.65017386231709!3d-6.917815137734711!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e68e7fa5a41c0bf%3A0x92717a360474c3c6!2sKec.%20Antapani%2C%20Kota%20Bandung%2C%20Jawa%20Barat!5e0!3m2!1sid!2sid!4v1773117484384!5m2!1sid!2sid" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>',
};
---

<section id="gift" class="py-20 bg-blush px-4 text-center overflow-hidden">
    <div class="max-w-4xl mx-auto">
        <!-- Judul Bagian -->
        <h2 class="font-serif text-4xl text-gold mb-6 italic">Wedding Gift</h2>
        <p class="text-gray-600 mb-12 max-w-2xl mx-auto">
            Doa restu Anda merupakan karunia terindah bagi kami. Namun jika Anda
            ingin memberikan tanda kasih, Anda dapat mengirimkannya melalui:
        </p>

        <div class="grid md:grid-cols-2 gap-8 mb-16">
            <!-- Rekening 1 (BCA) -->
            <div
                class="bg-white p-8 rounded-2xl shadow-xl border border-gold/10 flex flex-col items-center hover:shadow-2xl transition-all duration-500 group"
            >
                <div
                    class="h-12 flex items-center mb-6 group-hover:scale-110 transition-transform duration-500"
                >
                    <img
                        src={BANK_BCA.logo}
                        alt="BCA Logo"
                        class="h-full object-contain"
                    />
                </div>
                <p
                    class="text-2xl font-mono text-gold mb-2 tracking-widest font-bold"
                >
                    {BANK_BCA.number}
                </p>
                <p class="text-gray-500 mb-6 italic">a.n {BANK_BCA.owner}</p>

                <div class="relative flex flex-col items-center w-full">
                    <!-- Tombol Salin dengan Rekening BCA -->
                    <button
                        data-copy={BANK_BCA.number}
                        class="copy-btn w-full max-w-[200px] relative overflow-hidden bg-linear-to-r from-gold via-[#F5D17E] to-gold bg-size-[200%_auto] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-position-[100%_center] transition-all duration-500 active:scale-95 shadow-md hover:shadow-gold/20"
                    >
                        <span>Salin No. Rekening</span>
                    </button>
                    <!-- Notifikasi Berhasil (Muncul di bawah tombol) -->
                    <p
                        class="copy-success opacity-0 transform translate-y-2 text-xs text-green-600 font-medium mt-2 transition-all duration-300"
                    >
                        ✓ Berhasil Disalin!
                    </p>
                </div>
            </div>

            <!-- Rekening 2 (Mandiri) -->
            <div
                class="bg-white p-8 rounded-2xl shadow-xl border border-gold/10 flex flex-col items-center hover:shadow-2xl transition-all duration-500 group"
            >
                <div
                    class="h-10 flex items-center mb-6 group-hover:scale-110 transition-transform duration-500"
                >
                    <img
                        src={BANK_MANDIRI.logo}
                        alt="Mandiri Logo"
                        class="h-full object-contain"
                    />
                </div>
                <p
                    class="text-2xl font-mono text-gold mb-2 tracking-widest font-bold"
                >
                    {BANK_MANDIRI.number}
                </p>
                <p class="text-gray-500 mb-6 italic">
                    a.n {BANK_MANDIRI.owner}
                </p>

                <div class="relative flex flex-col items-center w-full">
                    <!-- Tombol Salin dengan Rekening Mandiri -->
                    <button
                        data-copy={BANK_MANDIRI.number}
                        class="copy-btn w-full max-w-[200px] relative overflow-hidden bg-linear-to-r from-gold via-[#F5D17E] to-gold bg-size-[200%_auto] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-position-[100%_center] transition-all duration-500 active:scale-95 shadow-md hover:shadow-gold/20"
                    >
                        <span>Salin No. Rekening</span>
                    </button>
                    <!-- Notifikasi Berhasil (Muncul di bawah tombol) -->
                    <p
                        class="copy-success opacity-0 transform translate-y-2 text-xs text-green-600 font-medium mt-2 transition-all duration-300"
                    >
                        ✓ Berhasil Disalin!
                    </p>
                </div>
            </div>
        </div>

        <!-- Alamat Pengiriman & Maps -->
        <!-- Optimalisasi layout: Memberikan padding dan border radius pada container Maps -->
        <div
            class="max-w-2xl mx-auto bg-white rounded-3xl shadow-2xl border border-gold/10 overflow-hidden"
        >
            <div class="p-8 pb-4 text-left">
                <h3
                    class="text-2xl font-serif text-dark-text mb-4 flex items-center gap-3"
                >
                    <div class="p-2 bg-gold/10 rounded-lg">
                        <svg
                            class="w-6 h-6 text-gold"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                    </div>
                    {SHIPPING_ADDRESS.title}
                </h3>
                <div
                    class="bg-gold/5 p-6 rounded-2xl border border-gold/10 mb-6"
                >
                    <p class="font-bold text-gray-800 mb-2 text-lg">
                        {SHIPPING_ADDRESS.receiver}
                    </p>
                    <p class="text-gray-600 leading-relaxed">
                        {SHIPPING_ADDRESS.fullAddress}
                    </p>
                </div>
            </div>

            <!-- Embed Map (Dinamis) dengan Spaging -->
            <!-- Memberikan margin/padding agar tidak menempel ke tepi (Permintaan User) -->
            <div class="px-6 pb-6">
                <div
                    class="w-full grayscale hover:grayscale-0 transition-all duration-700 rounded-2xl overflow-hidden shadow-inner border border-gray-100"
                >
                    <Fragment set:html={SHIPPING_ADDRESS.mapIframe} />
                </div>
            </div>

            <div
                class="p-4 bg-gray-50 text-gray-400 text-xs italic border-t border-gray-100"
            >
                *Silakan konfirmasi via WhatsApp sebelum pengiriman.
            </div>
        </div>
    </div>
</section>

<style>
    /* Animasi Klik Pulse untuk Tombol */
    @keyframes btn-pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.4);
        }
        70% {
            box-shadow: 0 0 0 10px rgba(212, 175, 55, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(212, 175, 55, 0);
        }
    }

    .btn-animated {
        animation: btn-pulse 0.6s ease-out;
    }

    /* Efek Berkilau pada Tombol saat Hover */
    .copy-btn::after {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(
            45deg,
            transparent,
            rgba(255, 255, 255, 0.3),
            transparent
        );
        transform: rotate(45deg);
        transition: 0.5s;
        opacity: 0;
    }

    .copy-btn:hover::after {
        opacity: 1;
        left: 100%;
    }
</style>

<script>
    // Inisialisasi fungsi salin nomor rekening
    const copyButtons = document.querySelectorAll(".copy-btn");

    copyButtons.forEach((btn) => {
        btn.addEventListener("click", async () => {
            const textToCopy = btn.getAttribute("data-copy") || "";
            const successMsg =
                btn.parentElement?.querySelector(".copy-success");

            try {
                // Gunakan Clipboard API
                await navigator.clipboard.writeText(textToCopy);

                // Tambahkan animasi klik
                btn.classList.add("btn-animated");
                setTimeout(() => btn.classList.remove("btn-animated"), 600);

                // Tampilkan pesan berhasil
                if (successMsg) {
                    successMsg.classList.remove("opacity-0", "translate-y-2");
                    successMsg.classList.add("opacity-100", "translate-y-0");

                    // Sembunyikan pesan setelah 2 detik
                    setTimeout(() => {
                        successMsg.classList.add("opacity-0", "translate-y-2");
                        successMsg.classList.remove(
                            "opacity-100",
                            "translate-y-0",
                        );
                    }, 2000);
                }
            } catch (err) {
                console.error("Gagal menyalin teks: ", err);
            }
        });
    });
</script>
